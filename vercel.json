{
  "version": 2,
  "builds": [
    {
      "src": "api.js",
      "use": "@vercel/node",
      "config": {
        "bundle": false,
        "includeFiles": ["node_modules/pg/**", "node_modules/pg-hstore/**"]
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api.js"
    }
  ]
}
